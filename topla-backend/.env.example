# ============================================
# TOPLA Backend - Environment Configuration
# ============================================

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database (PostgreSQL - Yandex Cloud Managed)
DATABASE_URL=postgresql://topla_user:your_password@rc1a-xxx.mdb.yandexcloud.net:6432/topla_db?sslmode=require
DATABASE_POOL_SIZE=20

# Redis (Yandex Cloud Managed)
REDIS_URL=redis://default:your_redis_password@c-xxx.rw.mdb.yandexcloud.net:6380
REDIS_PASSWORD=topla_redis_dev

# JWT (production da albatta o'zgartiring!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# Firebase (Google Sign-In + FCM push notifications)
# OTP Eskiz SMS orqali
FIREBASE_PROJECT_ID=topla-app-xxxxx
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@topla-app-xxxxx.iam.gserviceaccount.com

# S3 Storage (Yandex Object Storage - S3 compatible)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_PRODUCTS=topla-products
S3_BUCKET_SHOPS=topla-shops
S3_BUCKET_AVATARS=topla-avatars
S3_BUCKET_BANNERS=topla-banners

# FCM Push Notifications
FCM_SERVER_KEY=your_fcm_server_key

# Eskiz.uz SMS (https://eskiz.uz/sms - ro'yxatdan o'ting)
ESKIZ_EMAIL=your_eskiz_email@example.com
ESKIZ_PASSWORD=your_eskiz_password

# OTP Settings
OTP_LENGTH=5
OTP_TTL_SECONDS=120

# Payment (Aliance Bank / Octobank)
ALIANCE_API_LOGIN=your_aliance_login
ALIANCE_API_SECRET=your_aliance_secret
ALIANCE_WEBHOOK_SECRET=your_aliance_webhook_hmac_secret
OCTOBANK_API_LOGIN=your_octobank_login
OCTOBANK_API_SECRET=your_octobank_secret
OCTOBANK_WEBHOOK_SECRET=your_octobank_webhook_hmac_secret
PAYMENT_WEBHOOK_IPS=185.8.0.0/16,91.204.0.0/16
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-change-this

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://topla.uz

# Docker (used in docker-compose.yml)
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_USER=topla_user
POSTGRES_DB=topla_db

# Logging
LOG_LEVEL=info

# Error Tracking (Sentry) — ixtiyoriy, o'rnatilganda avtomatik yoqiladi
# https://sentry.io da projekt yarating va DSN ni qo'ying
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
