# =============================================
# TOPLA.UZ — Production Environment Variables
# Copy to .env and fill in real values
# =============================================

# ---- Database ----
POSTGRES_DB=topla_db
POSTGRES_USER=topla_user
POSTGRES_PASSWORD=     # Strong password here (min 24 chars)

# ---- Redis ----
REDIS_PASSWORD=        # Strong password here

# ---- JWT ----
JWT_SECRET=            # openssl rand -hex 32
JWT_REFRESH_SECRET=    # openssl rand -hex 32

# ---- Firebase (Push notifications) ----
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=  # Full private key from Firebase service account JSON

# ---- Yandex Object Storage (S3-compatible) ----
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_ACCESS_KEY=         # Yandex Cloud service account static key
S3_SECRET_KEY=         # Yandex Cloud service account secret key
S3_BUCKET_PRODUCTS=topla-products
S3_BUCKET_SHOPS=topla-shops
S3_BUCKET_AVATARS=topla-avatars

# ---- Eskiz SMS ----
ESKIZ_EMAIL=
ESKIZ_PASSWORD=

# ---- Payment providers (Aliance Bank / Octobank) ----
ALIANCE_API_LOGIN=
ALIANCE_API_SECRET=
ALIANCE_WEBHOOK_SECRET=
OCTOBANK_API_LOGIN=
OCTOBANK_API_SECRET=
OCTOBANK_WEBHOOK_SECRET=
PAYMENT_WEBHOOK_IPS=       # Comma-separated bank IP ranges

# ---- Meilisearch ----
MEILISEARCH_API_KEY=   # openssl rand -hex 16

# ---- Firebase Cloud Messaging ----
FCM_SERVER_KEY=
