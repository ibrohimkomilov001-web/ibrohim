# API
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Site URL (SEO, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Yandex Cloud Object Storage (images)
NEXT_PUBLIC_STORAGE_URL=https://storage.yandexcloud.net/topla-media

# Google Sign-In (shop profile + vendor + admin login)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# reCAPTCHA v3 site-key (admin login). Backend secret RECAPTCHA_SECRET_KEY
# is in topla-backend/.env
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Sentry (optional — error tracking)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=   # for source-map upload in CI

